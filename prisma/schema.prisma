// Prisma schema for Reda Hammad Academy — MySQL (Hostinger).
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// Key/value store for editable homepage content (hero, about, stats, videos...)
model SiteSetting {
  key       String   @id
  value     String   @default("") @db.LongText
  updatedAt DateTime @updatedAt
}

// Uploaded files stored directly in the DB so they survive redeploys
// (the host's filesystem is ephemeral). Served via /api/file/<id>.<ext>.
model Upload {
  id        Int      @id @default(autoincrement())
  mime      String   @default("application/octet-stream")
  data      Bytes
  createdAt DateTime @default(now())
}

model Course {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  description     String   @default("") @db.Text
  longDescription String   @default("") @db.Text
  curriculum      String   @default("[]") @db.Text
  features        String   @default("[]") @db.Text
  imageUrl        String   @default("") @db.Text
  price           String   @default("")
  currency        String   @default("ريال سعودي")
  platformUrl     String   @default("") @db.Text
  badge           String   @default("")
  category        String   @default("")
  paymentNote     String?  @db.Text
  showBankTransfer Boolean  @default(false)
  isPublished     Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
