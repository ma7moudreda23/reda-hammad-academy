// Prisma schema for Reda Hammad Academy
// Dev: SQLite (zero-config). Prod (Hostinger): can switch provider to "mysql".
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// Key/value store for editable homepage content (hero, about, stats, videos...)
model SiteSetting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

model Course {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  description     String   @default("")
  longDescription String   @default("")
  curriculum      String   @default("[]")
  features        String   @default("[]")
  imageUrl        String   @default("")
  price           String   @default("")
  currency        String   @default("ريال سعودي")
  platformUrl     String   @default("")
  badge           String   @default("")
  category        String   @default("")
  isPublished     Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
